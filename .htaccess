# Élégance Menuiseries — Configuration Apache

# Rediriger index.html vers index.php
DirectoryIndex index.php index.html

# Servir les fichiers PHP à la place des HTML (CMS dynamique)
RewriteEngine On
RewriteRule ^fenetres-portes-alu\.html$ fenetres-portes-alu.php [L]
RewriteRule ^fenetres-portes-pvc\.html$ fenetres-portes-pvc.php [L]
RewriteRule ^volets-roulants\.html$ volets-roulants.php [L]
RewriteRule ^portes-garage\.html$ portes-garage.php [L]
RewriteRule ^portails-clotures\.html$ portails-clotures.php [L]
RewriteRule ^mentions-legales\.html$ mentions-legales.php [L]
RewriteRule ^politique-confidentialite\.html$ politique-confidentialite.php [L]
RewriteRule ^politique-cookies\.html$ politique-cookies.php [L]

# Protéger les fichiers sensibles
<FilesMatch "^(content\.json|content\.json\.bak)$">
  Require all denied
</FilesMatch>

# Empêcher le listing des répertoires
Options -Indexes

# Protéger les fichiers .htaccess
<Files .htaccess>
  Require all denied
</Files>
